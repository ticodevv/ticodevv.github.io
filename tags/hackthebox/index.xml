&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="nv">uid&lt;/span>&lt;span class="o">=&lt;/span>1000&lt;span class="o">(&lt;/span>dvir&lt;span class="o">)&lt;/span> &lt;span class="nv">gid&lt;/span>&lt;span class="o">=&lt;/span>1000&lt;span class="o">(&lt;/span>dvir&lt;span class="o">)&lt;/span> &lt;span class="nv">euid&lt;/span>&lt;span class="o">=&lt;/span>0&lt;span class="o">(&lt;/span>dvir&lt;span class="o">)&lt;/span> &lt;span class="nv">groups&lt;/span>&lt;span class="o">=&lt;/span>1000&lt;span class="o">(&lt;/span>dvir&lt;span class="o">)&lt;/span>,100&lt;span class="o">(&lt;/span>users&lt;span class="o">)&lt;/span>
